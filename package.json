{
  "name": "cc-remote-term",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build",
    "test": "node --import tsx --test",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production tsx server.ts",
    "token:init": "node scripts/token-init.mjs",
    "token:copy": "bash scripts/token-copy.sh",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "idb": "^8.0.3",
    "next": "16.2.10",
    "node-pty": "^1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.2",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
